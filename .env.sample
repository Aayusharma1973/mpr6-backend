# MongoDB Connection
# Replace with your actual MongoDB connection string
MONGO_URI=your-mongodb-uri
MONGO_DB_NAME=your-mongodb-database-name

# Security
# Generate a long random string for production: openssl rand -hex 32
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=your-jwt-algorithm
JWT_EXPIRE_MINUTES=10080

# External APIs
# Your HuggingFace token for Qwen2-VL model access
HF_TOKEN=hf_your_token_here

# App Environment
APP_ENV=development
# Comma-separated list of allowed origins (e.g., your computer's IP for React Native)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,exp://localhost:8081

# Mongo Express (Admin UI)
ME_CONFIG_BASICAUTH_USERNAME=your-mongo-express-auth-username
ME_CONFIG_BASICAUTH_PASSWORD=your-mongo-express-auth-password
